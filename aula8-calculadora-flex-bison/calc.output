Grammar

    0 $accept: calc $end

    1 calc: calc expr '\n'
    2     | calc '\n'
    3     | %empty

    4 expr: expr '+' expr
    5     | expr '-' expr
    6     | expr '*' expr
    7     | expr '/' expr
    8     | expr FELIPE expr
    9     | '(' expr ')'
   10     | '-' expr
   11     | NUMBER


Terminals, with rules where they appear

    $end (0) 0
    '\n' (10) 1 2
    '(' (40) 9
    ')' (41) 9
    '*' (42) 6
    '+' (43) 4
    '-' (45) 5 10
    '/' (47) 7
    error (256)
    NUMBER (258) 11
    FELIPE (259) 8
    UMINUS (260)


Nonterminals, with rules where they appear

    $accept (13)
        on left: 0
    calc (14)
        on left: 1 2 3
        on right: 0 1 2
    expr (15)
        on left: 4 5 6 7 8 9 10 11
        on right: 1 4 5 6 7 8 9 10


State 0

    0 $accept: . calc $end

    $default  reduce using rule 3 (calc)

    calc  go to state 1


State 1

    0 $accept: calc . $end
    1 calc: calc . expr '\n'
    2     | calc . '\n'

    $end    shift, and go to state 2
    NUMBER  shift, and go to state 3
    '-'     shift, and go to state 4
    '\n'    shift, and go to state 5
    '('     shift, and go to state 6

    expr  go to state 7


State 2

    0 $accept: calc $end .

    $default  accept


State 3

   11 expr: NUMBER .

    $default  reduce using rule 11 (expr)


State 4

   10 expr: '-' . expr

    NUMBER  shift, and go to state 3
    '-'     shift, and go to state 4
    '('     shift, and go to state 6

    expr  go to state 8


State 5

    2 calc: calc '\n' .

    $default  reduce using rule 2 (calc)


State 6

    9 expr: '(' . expr ')'

    NUMBER  shift, and go to state 3
    '-'     shift, and go to state 4
    '('     shift, and go to state 6

    expr  go to state 9


State 7

    1 calc: calc expr . '\n'
    4 expr: expr . '+' expr
    5     | expr . '-' expr
    6     | expr . '*' expr
    7     | expr . '/' expr
    8     | expr . FELIPE expr

    FELIPE  shift, and go to state 10
    '+'     shift, and go to state 11
    '-'     shift, and go to state 12
    '*'     shift, and go to state 13
    '/'     shift, and go to state 14
    '\n'    shift, and go to state 15


State 8

    4 expr: expr . '+' expr
    5     | expr . '-' expr
    6     | expr . '*' expr
    7     | expr . '/' expr
    8     | expr . FELIPE expr
   10     | '-' expr .

    $default  reduce using rule 10 (expr)


State 9

    4 expr: expr . '+' expr
    5     | expr . '-' expr
    6     | expr . '*' expr
    7     | expr . '/' expr
    8     | expr . FELIPE expr
    9     | '(' expr . ')'

    FELIPE  shift, and go to state 10
    '+'     shift, and go to state 11
    '-'     shift, and go to state 12
    '*'     shift, and go to state 13
    '/'     shift, and go to state 14
    ')'     shift, and go to state 16


State 10

    8 expr: expr FELIPE . expr

    NUMBER  shift, and go to state 3
    '-'     shift, and go to state 4
    '('     shift, and go to state 6

    expr  go to state 17


State 11

    4 expr: expr '+' . expr

    NUMBER  shift, and go to state 3
    '-'     shift, and go to state 4
    '('     shift, and go to state 6

    expr  go to state 18


State 12

    5 expr: expr '-' . expr

    NUMBER  shift, and go to state 3
    '-'     shift, and go to state 4
    '('     shift, and go to state 6

    expr  go to state 19


State 13

    6 expr: expr '*' . expr

    NUMBER  shift, and go to state 3
    '-'     shift, and go to state 4
    '('     shift, and go to state 6

    expr  go to state 20


State 14

    7 expr: expr '/' . expr

    NUMBER  shift, and go to state 3
    '-'     shift, and go to state 4
    '('     shift, and go to state 6

    expr  go to state 21


State 15

    1 calc: calc expr '\n' .

    $default  reduce using rule 1 (calc)


State 16

    9 expr: '(' expr ')' .

    $default  reduce using rule 9 (expr)


State 17

    4 expr: expr . '+' expr
    5     | expr . '-' expr
    6     | expr . '*' expr
    7     | expr . '/' expr
    8     | expr . FELIPE expr
    8     | expr FELIPE expr .

    $default  reduce using rule 8 (expr)


State 18

    4 expr: expr . '+' expr
    4     | expr '+' expr .
    5     | expr . '-' expr
    6     | expr . '*' expr
    7     | expr . '/' expr
    8     | expr . FELIPE expr

    FELIPE  shift, and go to state 10
    '*'     shift, and go to state 13
    '/'     shift, and go to state 14

    $default  reduce using rule 4 (expr)


State 19

    4 expr: expr . '+' expr
    5     | expr . '-' expr
    5     | expr '-' expr .
    6     | expr . '*' expr
    7     | expr . '/' expr
    8     | expr . FELIPE expr

    FELIPE  shift, and go to state 10
    '*'     shift, and go to state 13
    '/'     shift, and go to state 14

    $default  reduce using rule 5 (expr)


State 20

    4 expr: expr . '+' expr
    5     | expr . '-' expr
    6     | expr . '*' expr
    6     | expr '*' expr .
    7     | expr . '/' expr
    8     | expr . FELIPE expr

    $default  reduce using rule 6 (expr)


State 21

    4 expr: expr . '+' expr
    5     | expr . '-' expr
    6     | expr . '*' expr
    7     | expr . '/' expr
    7     | expr '/' expr .
    8     | expr . FELIPE expr

    $default  reduce using rule 7 (expr)
